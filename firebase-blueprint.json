{
  "entities": {
    "NewsItem": {
      "title": "NewsItem",
      "description": "Represents an election-related news article or update.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the news item." },
        "summary": { "type": "string", "description": "A brief summary of the news." },
        "source": { "type": "string", "description": "The source of the news." },
        "url": { "type": "string", "description": "Link to the full article." },
        "publishedAt": { "type": "string", "description": "ISO date string." },
        "category": { "type": "string", "description": "Category e.g. 'National', 'Local', 'Voting Rules'." }
      },
      "required": ["title", "summary", "source", "publishedAt"]
    }
  },
  "firestore": {
    "/news/{newsId}": {
      "schema": "NewsItem",
      "description": "Collection of election-related news items."
    }
  }
}
