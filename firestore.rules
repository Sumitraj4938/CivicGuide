rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // News collection: Publicly readable, admin writable
    match /news/{newsId} {
      allow read: if true;
      allow write: if false; // Only manageable via Firebase Console or Admin SDK for this demo
    }
  }
}
